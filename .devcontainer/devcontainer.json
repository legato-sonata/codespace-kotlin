{
  "name": "Android Kotlin Development",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/sshd:1": {
      "version": "latest"
    }
  },
  "remoteUser": "vscode",
  "remoteEnv": {
    "ANDROID_SDK_ROOT": "/opt/android-sdk"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "mathiasfrohlich.Kotlin",
        "fwcd.kotlin",
        "vscjava.vscode-java-pack"
      ]
    }
  }
}
